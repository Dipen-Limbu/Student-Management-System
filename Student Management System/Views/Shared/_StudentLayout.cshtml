<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Scholaris</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: '#2563eb',
                        primaryHover: '#1d4ed8',
                        bgSoft: '#f8fafc',
                        textDark: '#0f172a',
                        textMuted: '#64748b'
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bgSoft text-textDark font-sans antialiased h-screen flex flex-col overflow-hidden">

    <!-- Top Navbar -->
    <header class="flex items-center justify-between px-6 py-3 bg-white border-b border-gray-200 shrink-0">
        <!-- Logo -->
        <div class="flex items-center gap-3 w-64">
            <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-md">
                <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />
                </svg>
            </div>
            <div>
                <h1 class="text-base font-bold leading-tight">Scholaris</h1>
                <p class="text-xs text-textMuted">Student Management</p>
            </div>
        </div>

        <!-- Search Bar -->
        <div class="flex-1 max-w-xl mx-4">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" class="block w-full pl-10 pr-3 py-2 border border-gray-200 rounded-full leading-5 bg-gray-50 placeholder-gray-400 focus:outline-none focus:bg-white focus:ring-1 focus:ring-primary focus:border-primary sm:text-sm transition-colors" placeholder="Search students, teachers, courses...">
            </div>
        </div>

        <!-- Right Actions -->
        <div class="flex items-center gap-5">
            <button class="relative p-2 text-gray-400 hover:text-gray-500 transition-colors rounded-full hover:bg-gray-100">
                <span class="absolute top-1.5 right-2 block h-2 w-2 rounded-full bg-red-500 ring-2 ring-white"></span>
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
            </button>
            <div class="flex items-center gap-3 border border-gray-200 rounded-full p-1 pr-4 bg-white cursor-pointer hover:shadow-sm transition-shadow">
                <div class="w-8 h-8 rounded-full bg-blue-100 text-primary flex items-center justify-center font-bold text-sm">
                    SS
                </div>
                <div class="flex flex-col">
                    <span class="text-sm font-semibold leading-none mb-1">Sara Student</span>
                    <span class="text-xs text-textMuted leading-none">Student</span>
                </div>
            </div>
        </div>
    </header>

    <div class="flex flex-1 overflow-hidden">
        <!-- Sidebar Navigation -->
        <nav class="w-64 bg-white border-r border-gray-200 flex flex-col justify-between overflow-y-auto shrink-0 py-4">
            <ul class="flex flex-col gap-1 px-3">
                <li>
                    <a asp-controller="Student" asp-action="Dashboard" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                        Dashboard
                    </a>
                </li>
                <li>
                    <a asp-controller="Student" asp-action="MyCourse" class="@(ViewContext.RouteData.Values["Action"].ToString() == "MyCourse" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        My Course
                    </a>
                </li>
                <li>
                    <a asp-controller="Student" asp-action="MyClass" class="@(ViewContext.RouteData.Values["Action"].ToString() == "MyClass" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                        My Class
                    </a>
                </li>
                <li>
                    <a asp-controller="Student" asp-action="Attendance" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Attendance" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                        Attendance
                    </a>
                </li>
                <li>
                    <a asp-controller="Student" asp-action="Profile" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Profile" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                        Profile
                    </a>
                </li>
                <li>
                    <a asp-controller="Student" asp-action="ChangePassword" class="@(ViewContext.RouteData.Values["Action"].ToString() == "ChangePassword" ? "bg-blue-50 text-primary font-semibold" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900") flex items-center gap-3 px-4 py-2.5 rounded-xl transition-colors text-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                        Change Password
                    </a>
                </li>
            </ul>

            <div class="px-3 pb-4">
                <a asp-controller="Login" asp-action="Logout" class="flex items-center gap-3 px-4 py-2.5 text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl transition-colors text-sm font-medium w-full">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Logout
                </a>
            </div>
        </nav>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto p-8 relative">
            @RenderBody()
        </main>
    </div>

</body>
</html>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Student_Management_System.styles.css" asp-append-version="true" />

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background: #fff;
        }

        /* ── Navbar ── */
        .scholaris-nav {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255,255,255,0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            height: 58px;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 0.55rem;
            text-decoration: none;
            color: #111827;
        }

        .nav-brand-icon {
            width: 32px; height: 32px;
            background: #2563eb;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .nav-brand-icon svg { width: 18px; height: 18px; color: #fff; }

        .nav-brand-name {
            font-size: 1.05rem;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            font-size: 0.88rem;
            font-weight: 500;
            color: #4b5563;
            text-decoration: none;
            padding: 0.45rem 0.85rem;
            border-radius: 8px;
            transition: color 0.15s, background 0.15s;
        }

        .nav-links a:hover {
            color: #111827;
            background: #f9fafb;
        }

        .nav-cta {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .nav-btn-login {
            font-size: 0.88rem;
            font-weight: 600;
            color: #374151;
            text-decoration: none;
            padding: 0.45rem 1rem;
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            transition: border-color 0.15s, background 0.15s;
        }
        .nav-btn-login:hover { border-color: #2563eb; color: #2563eb; background: #eff6ff; }

        .nav-btn-register {
            font-size: 0.88rem;
            font-weight: 600;
            color: #fff;
            text-decoration: none;
            padding: 0.45rem 1.1rem;
            background: #2563eb;
            border-radius: 8px;
            transition: background 0.15s, box-shadow 0.15s;
        }
        .nav-btn-register:hover { background: #1d4ed8; box-shadow: 0 2px 8px rgba(37,99,235,0.35); }

        /* ── Footer ── */
        .scholaris-footer {
            background: #0f172a;
            color: rgba(255,255,255,0.55);
            text-align: center;
            padding: 1.5rem 2rem;
            font-size: 0.82rem;
        }

        .scholaris-footer a {
            color: rgba(255,255,255,0.55);
            text-decoration: none;
        }
        .scholaris-footer a:hover { color: #fff; }
    </style>
</head>
<body>

    <nav class="scholaris-nav">
        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <div class="nav-brand-icon">
                <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 14l9-5-9-5-9 5 9 5zm0 0v6" />
                </svg>
            </div>
            <span class="nav-brand-name">Scholaris</span>
        </a>

        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
        </ul>

        <div class="nav-cta">
            <a asp-controller="Login" asp-action="Login" class="nav-btn-login">Login</a>
            <a asp-controller="Register" asp-action="Register" class="nav-btn-register">Register</a>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="scholaris-footer">
        <div>
            © 2026 Scholaris. Crafted for modern education. &nbsp;·&nbsp;
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

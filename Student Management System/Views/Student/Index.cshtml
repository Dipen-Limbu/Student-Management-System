@model IEnumerable<Student_Management_System.Models.Student>

@{
    ViewData["Title"] = "Students";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-textDark mb-1">Students</h2>
            <p class="text-textMuted text-sm">@Model.Count() students in your directory</p>
        </div>
        <div>
            <a asp-action="Create" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-white bg-[#2563eb] rounded-xl hover:bg-blue-700 shadow-sm transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Add student
            </a>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="bg-white rounded-t-2xl border border-b-0 border-gray-200 p-4 shadow-[0_1px_2px_rgba(0,0,0,0.02)] flex flex-col md:flex-row gap-3">
        <form method="get" asp-action="Index" class="flex-1 flex flex-col md:flex-row gap-3 w-full">
            <div class="relative flex-1">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" name="searchString" value="@Context.Request.Query["searchString"]" class="block w-full pl-10 pr-3 py-2 border border-gray-200 rounded-xl leading-5 bg-white placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary sm:text-sm transition-colors" placeholder="Search by name, email or roll #">
            </div>
            <div class="flex gap-3">
                <select name="status" class="block w-full py-2 pl-3 pr-10 border border-gray-200 bg-white rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-gray-700 transition-colors" onchange="this.form.submit()">
                    <option value="">All statuses</option>
                    <option value="active" selected="@(Context.Request.Query["status"] == "active")">Active</option>
                    <option value="inactive" selected="@(Context.Request.Query["status"] == "inactive")">Inactive</option>
                </select>
                <select name="course" class="block w-full py-2 pl-3 pr-10 border border-gray-200 bg-white rounded-xl text-sm focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-gray-700 transition-colors" onchange="this.form.submit()">
                    <option value="">All courses</option>
                    <option value="CS101" selected="@(Context.Request.Query["course"] == "CS101")">CS101</option>
                    <option value="MA201" selected="@(Context.Request.Query["course"] == "MA201")">MA201</option>
                    <option value="PH110" selected="@(Context.Request.Query["course"] == "PH110")">PH110</option>
                </select>
                <button type="submit" class="hidden">Search</button>
            </div>
        </form>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-b-2xl border border-gray-200 shadow-[0_1px_2px_rgba(0,0,0,0.02)] overflow-hidden mb-6">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-xs font-semibold text-textMuted uppercase tracking-wider border-b border-gray-100 bg-white">
                        <th class="px-6 py-4">STUDENT</th>
                        <th class="px-6 py-4 text-center">ROLL #</th>
                        <th class="px-6 py-4 text-center">COURSE</th>
                        <th class="px-6 py-4 text-center">SEMESTER</th>
                        <th class="px-6 py-4 text-center">STATUS</th>
                        <th class="px-6 py-4 text-right">ACTIONS</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-sm bg-white">
                    @foreach(var item in Model)
                    {
                        <tr class="hover:bg-gray-50 transition-colors group">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-xs border border-blue-100">
                                        @item.Initials
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="font-medium text-textDark">@item.FullName</span>
                                        <span class="text-xs text-textMuted">@item.Email</span>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-center text-textMuted whitespace-nowrap">@item.RollNo</td>
                            <td class="px-6 py-4 text-center text-textMuted whitespace-nowrap">@item.Course</td>
                            <td class="px-6 py-4 text-center text-textMuted whitespace-nowrap">@item.Semester</td>
                            <td class="px-6 py-4 text-center whitespace-nowrap">
                                @if (item.Status?.ToLower() == "active")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-600 border border-green-100">active</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">Inactive</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right whitespace-nowrap">
                                <div class="flex justify-end gap-1.5 opacity-100">
                                    <a asp-action="Details" asp-route-id="@item.StudentId" class="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded border border-transparent hover:border-blue-100 transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.StudentId" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded border border-transparent hover:border-gray-200 transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.StudentId" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded border border-transparent hover:border-gray-200 transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Pagination footer -->
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between">
            <span class="text-sm text-textMuted">Page 1 of 6</span>
            <div class="flex gap-2">
                <button disabled class="px-3 py-1.5 border border-gray-200 text-gray-400 rounded-lg text-sm font-medium bg-gray-50 cursor-not-allowed">Previous</button>
                <button class="px-3 py-1.5 border border-gray-200 text-gray-700 hover:bg-gray-50 rounded-lg text-sm font-medium transition-colors">Next</button>
            </div>
        </div>
    </div>
</div>

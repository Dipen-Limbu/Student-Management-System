@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Scholaris</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        glass: {
                            50: 'rgba(255, 255, 255, 0.1)',
                            100: 'rgba(255, 255, 255, 0.3)',
                            200: 'rgba(255, 255, 255, 0.4)',
                            300: 'rgba(255, 255, 255, 0.5)',
                            border: 'rgba(255, 255, 255, 0.6)',
                        }
                    },
                    boxShadow: {
                        'glass': '0 8px 32px 0 rgba(31, 38, 135, 0.05), inset 0 1px 1px 0 rgba(255, 255, 255, 0.8), inset 0 -1px 1px 0 rgba(255, 255, 255, 0.3)',
                        'glass-sm': '0 4px 16px 0 rgba(31, 38, 135, 0.03), inset 0 1px 1px 0 rgba(255, 255, 255, 0.7)',
                        'glass-lg': '0 16px 48px 0 rgba(31, 38, 135, 0.08), inset 0 1px 1px 0 rgba(255, 255, 255, 0.9), inset 0 -1px 1px 0 rgba(255, 255, 255, 0.4)',
                        'glass-inner': 'inset 0 2px 4px 0 rgba(31, 38, 135, 0.04), inset 0 1px 1px 0 rgba(255, 255, 255, 0.6)',
                    }
                }
            }
        }
    </script>
</head>
<body class="font-sans text-slate-800 antialiased min-h-screen relative overflow-hidden bg-slate-50/50 selection:bg-blue-200">
    
    <!-- Dynamic Ambient Background for Liquid Glass Refraction -->
    <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] left-[-5%] w-[40rem] h-[40rem] bg-blue-300/20 rounded-full mix-blend-multiply filter blur-[100px] opacity-80 animate-[spin_60s_linear_infinite]"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[45rem] h-[45rem] bg-indigo-200/20 rounded-full mix-blend-multiply filter blur-[120px] opacity-80 animate-[spin_90s_linear_infinite_reverse]"></div>
        <div class="absolute top-[20%] left-[40%] w-[35rem] h-[35rem] bg-sky-200/20 rounded-full mix-blend-multiply filter blur-[90px] opacity-70 animate-[pulse_10s_ease-in-out_infinite]"></div>
    </div>

    <div class="flex h-screen w-full">
        <!-- Sidebar -->
        <aside class="w-[250px] flex flex-col h-full bg-glass-100 backdrop-blur-2xl border-r border-glass-border shadow-glass z-20 transition-all duration-300">
            <!-- Logo area -->
            <div class="h-[72px] flex items-center px-6 gap-3 flex-shrink-0">
                <div class="w-[34px] h-[34px] bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/40 relative overflow-hidden group cursor-pointer">
                    <div class="absolute inset-0 bg-gradient-to-tr from-transparent to-white/30"></div>
                    <svg class="w-5 h-5 text-white relative z-10 group-hover:scale-110 transition-transform duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
                    </svg>
                </div>
                <div class="flex flex-col">
                    <span class="font-bold text-[15px] leading-tight text-slate-800">Scholaris</span>
                    <span class="text-[11px] text-slate-500 font-medium">Student Management</span>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 bg-blue-50/70 backdrop-blur-md border border-white/80 shadow-glass-sm rounded-xl text-blue-600 font-semibold transition-all duration-300 relative group">
                    <div class="absolute inset-y-0 left-0 w-1 bg-blue-600 rounded-r-full shadow-[0_0_8px_rgba(37,99,235,0.6)]"></div>
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
                    </svg>
                    Dashboard
                </a>
                
                <!-- Other Links -->
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>
                    Students
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                    Teachers
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
                    Courses
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>
                    Classes
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75v-.008z" /></svg>
                    Attendance
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
                    Reports
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
                    Users
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
                    Profile
                </a>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    Settings
                </a>
            </nav>

            <!-- User Bottom -->
            <div class="p-4 mt-auto mb-2">
                <div class="flex items-center gap-3 px-3 py-2 mb-2 group cursor-pointer rounded-xl hover:bg-glass-100 hover:backdrop-blur-md transition-all duration-300">
                    <div class="w-9 h-9 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-sm shadow-glass-inner border border-white group-hover:shadow-glass-sm transition-all duration-300">
                        AA
                    </div>
                    <div class="flex flex-col">
                        <span class="font-semibold text-sm text-slate-800">Ada Admin</span>
                        <span class="text-xs text-slate-500">Admin</span>
                    </div>
                </div>
                <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-slate-600 font-medium rounded-xl hover:bg-glass-200 hover:backdrop-blur-md hover:border hover:border-white/60 hover:shadow-glass-sm hover:text-slate-900 transition-all duration-300 border border-transparent active:scale-[0.98]">
                    <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" /></svg>
                    Logout
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-y-auto relative z-10 scroll-smooth">
            
            <!-- Top Header (Liquid Glass) -->
            <header class="h-[72px] flex items-center justify-between px-8 bg-glass-100/50 backdrop-blur-xl border-b border-glass-border shadow-glass-sm sticky top-0 z-30 transition-all duration-300">
                
                <!-- Search -->
                <div class="relative w-[480px] group">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                        <svg class="w-4 h-4 text-slate-400 group-focus-within:text-blue-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
                    </div>
                    <input type="text" placeholder="Search students, teachers, courses..." class="w-full pl-10 pr-4 py-2 bg-glass-200 backdrop-blur-md border border-white/70 shadow-glass-inner rounded-xl outline-none focus:bg-glass-300 focus:border-white focus:ring-2 focus:ring-blue-500/20 focus:shadow-glass transition-all duration-300 text-sm text-slate-700 placeholder-slate-400">
                </div>

                <!-- Header Actions -->
                <div class="flex items-center gap-4">
                    <!-- Notification Bell -->
                    <button class="relative p-2.5 bg-glass-200 backdrop-blur-md border border-white/70 shadow-glass-inner rounded-xl hover:bg-glass-300 hover:shadow-glass-sm transition-all duration-300 group active:scale-95">
                        <div class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border border-white"></div>
                        <svg class="w-5 h-5 text-slate-600 group-hover:text-slate-900 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                    </button>
                    
                    <!-- Profile Badge -->
                    <div class="flex items-center gap-3 bg-glass-200 backdrop-blur-md border border-white/70 shadow-glass-inner rounded-xl pl-2 pr-4 py-1.5 cursor-pointer hover:bg-glass-300 hover:shadow-glass-sm transition-all duration-300 active:scale-95">
                        <div class="w-[30px] h-[30px] rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-xs border border-white shadow-sm">
                            AA
                        </div>
                        <div class="flex flex-col">
                            <span class="font-semibold text-sm text-slate-800 leading-tight">Ada Admin</span>
                            <span class="text-[11px] text-slate-500 leading-tight">Admin</span>
                        </div>
                    </div>
                </div>
            </header>
            
            <div class="p-8 space-y-6 max-w-[1400px]">
                
                <!-- Title Area -->
                <div>
                    <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Overview</h1>
                    <p class="text-sm text-slate-500 mt-1">Welcome back — here's what's happening on campus today.</p>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-4 gap-6">
                    <!-- Stat 1 -->
                    <div class="bg-glass-200 backdrop-blur-2xl border border-white/60 shadow-glass rounded-2xl p-5 hover:shadow-glass-lg hover:bg-glass-300 transition-all duration-300 group hover:-translate-y-1 relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-white/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-4">

                            <div class="absolute left-0 top-0 bottom-10 flex flex-col justify-between text-[11px] font-medium text-slate-400">
                                <span>100</span><span>75</span><span>50</span><span>25</span><span>0</span>
                            </div>
                            
                            <!-- Bars Area -->
                            <div class="absolute left-8 right-0 top-2 bottom-10">
                                <!-- Grid -->
                                <div class="absolute inset-0 flex flex-col justify-between">
                                    <div class="border-t border-slate-300/30 w-full h-0"></div>
                                    <div class="border-t border-slate-300/30 w-full h-0"></div>
                                    <div class="border-t border-slate-300/30 w-full h-0"></div>
                                    <div class="border-t border-slate-300/30 w-full h-0"></div>
                                    <div class="border-t border-slate-300/50 w-full h-0"></div>
                                </div>
                                
                                <!-- Columns -->
                                <div class="absolute inset-0 flex justify-between items-end px-3">
                                    <!-- Mon -->
                                    <div class="flex items-end gap-1.5 w-full justify-center h-full group pb-0 cursor-pointer">
                                        <div class="w-[14px] bg-blue-500 rounded-t-md group-hover:bg-blue-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 95%"></div>
                                        <div class="w-[14px] bg-red-500 rounded-t-md group-hover:bg-red-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 10%"></div>
                                    </div>
                                    <!-- Tue -->
                                    <div class="flex items-end gap-1.5 w-full justify-center h-full group pb-0 cursor-pointer">
                                        <div class="w-[14px] bg-blue-500 rounded-t-md group-hover:bg-blue-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 88%"></div>
                                        <div class="w-[14px] bg-red-500 rounded-t-md group-hover:bg-red-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 12%"></div>
                                    </div>
                                    <!-- Wed -->
                                    <div class="flex items-end gap-1.5 w-full justify-center h-full group pb-0 cursor-pointer">
                                        <div class="w-[14px] bg-blue-500 rounded-t-md group-hover:bg-blue-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 92%"></div>
                                        <div class="w-[14px] bg-red-500 rounded-t-md group-hover:bg-red-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 15%"></div>
                                    </div>
                                    <!-- Thu -->
                                    <div class="flex items-end gap-1.5 w-full justify-center h-full group pb-0 cursor-pointer">
                                        <div class="w-[14px] bg-blue-500 rounded-t-md group-hover:bg-blue-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 85%"></div>
                                        <div class="w-[14px] bg-red-500 rounded-t-md group-hover:bg-red-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 25%"></div>
                                    </div>
                                    <!-- Fri -->
                                    <div class="flex items-end gap-1.5 w-full justify-center h-full group pb-0 cursor-pointer">
                                        <div class="w-[14px] bg-blue-500 rounded-t-md group-hover:bg-blue-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 98%"></div>
                                        <div class="w-[14px] bg-red-500 rounded-t-md group-hover:bg-red-400 shadow-sm transition-all duration-300 group-hover:-translate-y-1" style="height: 5%"></div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- X-axis -->
                            <div class="absolute left-8 right-0 bottom-4 flex justify-between text-[11px] font-medium text-slate-500 px-5">
                                <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span>
                            </div>
                            
                            <!-- Legend -->
                            <div class="absolute left-0 right-0 bottom-[-15px] flex justify-center gap-5 text-[11px] text-slate-500 font-semibold tracking-wide translate-y-full">
                                <div class="flex items-center gap-2"><div class="w-3 h-3 bg-blue-500 rounded shadow-sm"></div>present</div>
                                <div class="flex items-center gap-2"><div class="w-3 h-3 bg-red-500 rounded shadow-sm"></div>absent</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="h-6"></div> <!-- Bottom Spacer -->
            </div>
        </main>
    </div>
</body>
</html>
@model Student_Management_System.Models.AdminProfileViewModel

@{
    ViewData["Title"] = "Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-textDark mb-1">Profile</h2>
        <p class="text-textMuted text-sm">Manage your personal information</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-100 flex items-center gap-3 text-green-700 text-sm font-medium">
            <svg class="w-5 h-5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
        
        <!-- Left Column: Profile Summary -->
        <div class="lg:col-span-1">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_1px_3px_rgba(0,0,0,0.02)] p-8 flex flex-col items-center text-center">
                
                <!-- Avatar -->
                <div class="relative mb-5">
                    <div class="w-32 h-32 rounded-full bg-[#eef2ff] text-[#2563eb] flex items-center justify-center font-bold text-4xl shadow-inner">
                        @Model.Initials
                    </div>
                    <!-- Camera Badge -->
                    <button type="button" class="absolute bottom-1 right-1 w-9 h-9 bg-[#2563eb] hover:bg-blue-700 transition-colors rounded-full border-4 border-white flex items-center justify-center text-white shadow-sm" title="Change picture">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </button>
                </div>

                <!-- Info -->
                <h3 class="text-xl font-bold text-gray-900 leading-tight">@Model.FullName</h3>
                <p class="text-sm text-gray-500 mt-1">@Model.Email</p>
                <div class="mt-3">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-[#eef2ff] text-[#2563eb]">
                        @Model.Role
                    </span>
                </div>

                <!-- Action -->
                <button type="button" class="mt-8 w-full px-4 py-2.5 bg-white border border-gray-200 text-gray-700 text-sm font-semibold rounded-xl hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-200 transition-colors flex items-center justify-center gap-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
                    Change password
                </button>

            </div>
        </div>

        <!-- Right Column: Edit Profile Form -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_1px_3px_rgba(0,0,0,0.02)] p-6 md:p-8 h-full">
                <h3 class="text-lg font-bold text-gray-900 mb-6">Edit profile</h3>
                
                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <div class="space-y-1.5">
                            <label asp-for="FirstName" class="block text-sm font-semibold text-gray-700">First name</label>
                            <input asp-for="FirstName" class="block w-full px-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 sm:text-sm transition-all" />
                            <span asp-validation-for="FirstName" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="LastName" class="block text-sm font-semibold text-gray-700">Last name</label>
                            <input asp-for="LastName" class="block w-full px-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 sm:text-sm transition-all" />
                            <span asp-validation-for="LastName" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5 md:col-span-2">
                            <label asp-for="Email" class="block text-sm font-semibold text-gray-700">Email</label>
                            <input asp-for="Email" type="email" class="block w-full px-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 sm:text-sm transition-all" />
                            <span asp-validation-for="Email" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1.5 md:col-span-2">
                            <label asp-for="Phone" class="block text-sm font-semibold text-gray-700">Phone</label>
                            <input asp-for="Phone" class="block w-full px-4 py-2.5 border border-gray-200 rounded-xl bg-gray-50/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 sm:text-sm transition-all" />
                            <span asp-validation-for="Phone" class="text-xs text-red-500"></span>
                        </div>

                    </div>

                    <div class="mt-8 flex justify-end">
                        <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-[#2563eb] border border-transparent rounded-xl hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 shadow-sm transition-colors flex items-center justify-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                            Save changes
                        </button>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@model Student_Management_System.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-textDark mb-1">Overview</h2>
        <p class="text-textMuted text-sm">Welcome back — here's what's happening on campus today.</p>
    </div>

    <!-- Summary Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        
        <!-- Total Students -->
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-medium text-textMuted">Total Students</span>
                <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-500 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path></svg>
                </div>
            </div>
            <div>
                <h3 class="text-3xl font-bold text-textDark mb-2">@Model.TotalStudents</h3>
                <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
                        @Model.StudentsTrend
                    </span>
                </div>
            </div>
        </div>

        <!-- Total Teachers -->
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-medium text-textMuted">Total Teachers</span>
                <div class="w-8 h-8 rounded-full bg-cyan-50 text-cyan-500 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
            </div>
            <div>
                <h3 class="text-3xl font-bold text-textDark mb-2">@Model.TotalTeachers</h3>
                <div class="flex items-center gap-2">
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">
                        @Model.TeachersTrend
                    </span>
                </div>
            </div>
        </div>

        <!-- Total Courses -->
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-medium text-textMuted">Total Courses</span>
                <div class="w-8 h-8 rounded-xl bg-green-50 text-green-600 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
            </div>
            <div>
                <h3 class="text-3xl font-bold text-textDark mb-2">@Model.TotalCourses</h3>
                <p class="text-xs text-textMuted">@Model.CoursesSubtext</p>
            </div>
        </div>

        <!-- Total Classes -->
        <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm flex flex-col justify-between">
            <div class="flex justify-between items-center mb-4">
                <span class="text-sm font-medium text-textMuted">Total Classes</span>
                <div class="w-8 h-8 rounded-xl bg-orange-50 text-orange-500 flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                </div>
            </div>
            <div>
                <h3 class="text-3xl font-bold text-textDark mb-2">@Model.TotalClasses</h3>
                <p class="text-xs text-textMuted">@Model.ClassesSubtext</p>
            </div>
        </div>

    </div>

    <!-- Main Content Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column (Wider) -->
        <div class="lg:col-span-2 flex flex-col gap-6">
            
            <!-- Enrollment Trend Chart -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h3 class="text-base font-bold text-textDark">Enrollment trend</h3>
                        <p class="text-sm text-textMuted">Students enrolled per month</p>
                    </div>
                    <span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs font-semibold rounded-md">YTD</span>
                </div>
                <div class="h-[250px] w-full relative">
                    <canvas id="enrollmentChart"></canvas>
                </div>
            </div>

            <!-- Recent Students Table -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center">
                    <h3 class="text-base font-bold text-textDark">Recent students</h3>
                    <a href="#" class="text-sm font-semibold text-blue-600 hover:text-blue-700">View all</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs font-semibold text-textMuted uppercase tracking-wider">
                                <th class="px-6 py-4">Student</th>
                                <th class="px-6 py-4 text-center">Roll #</th>
                                <th class="px-6 py-4 text-center">Course</th>
                                <th class="px-6 py-4 text-right">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 text-sm">
                            @foreach(var student in Model.RecentStudents)
                            {
                                <tr class="hover:bg-gray-50 transition-colors group">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center font-semibold text-xs border border-blue-100">
                                                @student.Initials
                                            </div>
                                            <div class="flex flex-col">
                                                <span class="font-medium text-textDark">@student.Name</span>
                                                <span class="text-xs text-textMuted">@student.Email</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-center text-textMuted whitespace-nowrap">@student.RollNo</td>
                                    <td class="px-6 py-4 text-center text-textMuted whitespace-nowrap">@student.Course</td>
                                    <td class="px-6 py-4 text-right whitespace-nowrap">
                                        @if (student.IsActive)
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-600 border border-green-100">active</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200">inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- Right Column (Narrower) -->
        <div class="lg:col-span-1 flex flex-col gap-6">
            
            <!-- Recent Activity -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="text-base font-bold text-textDark mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    Recent activity
                </h3>
                <div class="space-y-6">
                    @foreach(var activity in Model.RecentActivity)
                    {
                        <div class="flex gap-4 relative">
                            <!-- Timeline dot -->
                            <div class="relative flex-shrink-0 mt-1">
                                <div class="w-2.5 h-2.5 bg-blue-500 rounded-full z-10 relative"></div>
                                <div class="absolute top-3 left-1/2 -ml-px w-px h-full bg-gray-200 -z-0"></div>
                            </div>
                            <div class="flex flex-col pb-1">
                                <p class="text-sm text-textDark leading-snug">
                                    <span class="font-semibold">@activity.UserName</span> 
                                    <span class="text-textMuted">@activity.ActionText</span> 
                                    <span class="font-medium">@activity.TargetName</span>
                                </p>
                                <span class="text-xs text-textMuted mt-1">@activity.TimeAgo</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Weekly Attendance Chart -->
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                <h3 class="text-base font-bold text-textDark mb-6">Weekly attendance</h3>
                <div class="h-[200px] w-full relative">
                    <canvas id="attendanceChart"></canvas>
                </div>
                <div class="flex justify-center gap-4 mt-4">
                    <div class="flex items-center gap-1.5">
                        <div class="w-3 h-3 bg-[#3b82f6] rounded-sm"></div>
                        <span class="text-xs text-textMuted">present</span>
                    </div>
                    <div class="flex items-center gap-1.5">
                        <div class="w-3 h-3 bg-[#ef4444] rounded-sm"></div>
                        <span class="text-xs text-textMuted">absent</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="fixed bottom-6 right-6 bg-white border border-gray-100 shadow-lg rounded-xl p-4 flex items-center gap-3 transform translate-y-20 opacity-0 transition-all duration-300 z-50">
    <div class="w-6 h-6 rounded-full bg-black text-white flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
    </div>
    <span class="text-sm font-semibold text-textDark">Welcome back, @Model.AdminName!</span>
    <button onclick="document.getElementById('toast').style.display='none'" class="ml-4 text-gray-400 hover:text-gray-600">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
</div>

<!-- Scripts for Charts and Toast -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        
        // Show Toast only once per login session
        if (!sessionStorage.getItem('welcomeShown')) {
            setTimeout(() => {
                const toast = document.getElementById('toast');
                if (toast) toast.classList.remove('translate-y-20', 'opacity-0');
            }, 500);
            setTimeout(() => {
                const toast = document.getElementById('toast');
                if (toast) toast.classList.add('translate-y-20', 'opacity-0');
            }, 5000);
            sessionStorage.setItem('welcomeShown', 'true');
        }

        // Chart.js Configuration
        const ctxEnrollment = document.getElementById('enrollmentChart').getContext('2d');
        const gradient = ctxEnrollment.createLinearGradient(0, 0, 0, 250);
        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.2)');
        gradient.addColorStop(1, 'rgba(59, 130, 246, 0)');

        new Chart(ctxEnrollment, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug'],
                datasets: [{
                    label: 'Students',
                    data: [210, 240, 260, 275, 290, 320, 350, 400],
                    borderColor: '#3b82f6',
                    backgroundColor: gradient,
                    borderWidth: 2,
                    pointRadius: 0,
                    pointHoverRadius: 4,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: {
                        grid: { display: false, drawBorder: false },
                        ticks: { color: '#64748b', font: { size: 11, family: 'Inter' } }
                    },
                    y: {
                        grid: { color: '#f1f5f9', borderDash: [4, 4], drawBorder: false },
                        ticks: { color: '#64748b', font: { size: 11, family: 'Inter' }, stepSize: 100 }
                    }
                }
            }
        });

        // Weekly Attendance Chart
        const ctxAttendance = document.getElementById('attendanceChart').getContext('2d');
        new Chart(ctxAttendance, {
            type: 'bar',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'],
                datasets: [
                    {
                        label: 'Present',
                        data: [92, 88, 90, 85, 95],
                        backgroundColor: '#3b82f6',
                        borderRadius: 4,
                        barPercentage: 0.6,
                        categoryPercentage: 0.4
                    },
                    {
                        label: 'Absent',
                        data: [8, 12, 10, 15, 5],
                        backgroundColor: '#ef4444',
                        borderRadius: 4,
                        barPercentage: 0.6,
                        categoryPercentage: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: {
                        stacked: false,
                        grid: { display: false, drawBorder: false },
                        ticks: { color: '#64748b', font: { size: 11, family: 'Inter' } }
                    },
                    y: {
                        grid: { color: '#f1f5f9', borderDash: [4, 4], drawBorder: false },
                        ticks: { color: '#64748b', font: { size: 11, family: 'Inter' }, max: 100, stepSize: 25 }
                    }
                }
            }
        });
    });
</script>

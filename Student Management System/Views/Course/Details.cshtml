@model Student_Management_System.Models.Course

@{
    ViewData["Title"] = "Course Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-textDark mb-1">Course Details</h2>
            <p class="text-textMuted text-sm">View comprehensive information for @Model.CourseCode.</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" class="inline-flex items-center text-sm font-semibold text-gray-600 hover:text-gray-900 transition-colors">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                Back to courses
            </a>
            <a asp-action="Edit" asp-route-id="@Model?.CourseId" class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-[#2563eb] rounded-xl hover:bg-blue-700 shadow-sm transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                Edit Course
            </a>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_1px_2px_rgba(0,0,0,0.02)] overflow-hidden">
        
        <!-- Course Header Banner -->
        <div class="@Model.BannerColor h-32 p-8 flex items-end relative">
             <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
             <div class="relative z-10 w-full flex items-center justify-between">
                 <h3 class="text-2xl font-bold text-white tracking-wide">@Model.CourseCode</h3>
             </div>
        </div>

        <div class="p-6 md:p-8">
            <div class="mb-8">
                <h3 class="text-3xl font-bold text-gray-900 mb-3">@Model.CourseName</h3>
                <p class="text-gray-600 text-lg leading-relaxed max-w-3xl">@Model.Description</p>
            </div>

            <!-- Details Grid -->
            <dl class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-6 bg-gray-50 p-6 rounded-xl border border-gray-100">
                <div>
                    <dt class="text-sm font-medium text-gray-500 mb-1 flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        Credits
                    </dt>
                    <dd class="text-xl text-gray-900 font-bold">@Model.Credits</dd>
                </div>
                
                <div>
                    <dt class="text-sm font-medium text-gray-500 mb-1 flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Duration
                    </dt>
                    <dd class="text-xl text-gray-900 font-bold">@(Model.Duration ?? "N/A")</dd>
                </div>
                
                <div>
                    <dt class="text-sm font-medium text-gray-500 mb-1 flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                        Enrolled Students
                    </dt>
                    <dd class="text-xl text-gray-900 font-bold">@(Model.EnrolledStudents ?? 0)</dd>
                </div>
            </dl>
        </div>
        
    </div>
</div>
